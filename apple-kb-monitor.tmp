#!/usr/bin/env python3
"""apple-kb-monitor — Full telemetry for Apple Wireless Keyboards (BCM2042/BCM20733).

Reads all available data from Apple Bluetooth keyboards by decoding
undocumented HID Feature Reports exposed by the Broadcom controller:

  Documented:
    0x47  Battery Strength (0-100%)

  Reverse-engineered:
    0xEA  Battery precise (pre-rounding ADC-derived percentage)
    0xF5  Battery voltage raw ADC (10-bit, 3.3V reference)
    0xF4  ADC reference / calibration value
    0x5A  Discharge curve calibration (4 voltage thresholds)
    0x5B  Voltage reference pair (copy of 0xF4 + 0xF5)
    0x4F  Firmware version
    0x51-0x53  Device name string (3 chunks)
    0x4C  Device identity key (128-bit)
    0x46  BT connection parameters (interval, latency)
    0x49  BT timing parameters
    0x4A  Power management config
    0x4B  Device mode/class
    0x09  Device state flag
    0xFF  Build/revision number
    0xF6-0xF7  Config registers

  External (BlueZ):
    RSSI, TX power via MGMT socket
    Device properties via D-Bus

Usage:
    apple-kb-monitor                        # daemon mode
    apple-kb-monitor --once                 # quick battery check
    apple-kb-monitor --status               # full device report
    apple-kb-monitor --dump                 # raw register dump
    apple-kb-monitor --watch [--interval N] # live dashboard
    apple-kb-monitor --json                 # JSON for integrations
    apple-kb-monitor --history              # battery/voltage log
"""

__version__ = "1.0.0"
__author__ = "Han (AgenceAPI)"
__license__ = "GPL-2.0-or-later"

import argparse
import fcntl
import glob
import json
import os
import signal
import struct
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

APPLE_VID = 0x05AC

# HID Feature Report IDs (BCM2042 / BCM20733)
REP_DEVICE_STATE   = 0x09
REP_BT_CONN_PARAMS = 0x46
REP_BATTERY_PCT    = 0x47  # Battery Strength (Usage Page 0x06, Usage 0x20)
REP_BT_TIMING      = 0x49
REP_POWER_CFG      = 0x4A
REP_MODE_CLASS     = 0x4B
REP_IDENTITY       = 0x4C  # 128-bit device identity
REP_FW_VERSION     = 0x4F
REP_NAME_1         = 0x51  # Device name chunk 1
REP_NAME_2         = 0x52  # Device name chunk 2
REP_NAME_3         = 0x53  # Device name chunk 3
REP_CALIB_CURVE    = 0x5A  # 4 ADC threshold values for discharge curve
REP_VOLT_REF       = 0x5B  # Voltage reference pair
REP_BATTERY_FINE   = 0xEA  # Battery precise (before rounding)
REP_ADC_REF        = 0xF4  # ADC reference/calibration
REP_ADC_VOLTAGE    = 0xF5  # Raw ADC battery voltage
REP_CFG_REG_1      = 0xF6
REP_CFG_REG_2      = 0xF7
REP_BUILD_REV      = 0xFF  # Firmware build/revision

HIDIOCGFEATURE = lambda length: 0xC0004807 | (length << 16)

# BlueZ MGMT
BTPROTO_HCI = 1
HCI_CHANNEL_CONTROL = 3
MGMT_OP_GET_CONN_INFO = 0x0031
MGMT_EV_CMD_COMPLETE = 0x0001

# ADC parameters (BCM2042: 10-bit ADC, 3.3V internal reference)
ADC_BITS = 10
ADC_MAX = (1 << ADC_BITS) - 1  # 1023
ADC_VREF = 3.3

# Paths
STATE_DIR = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "apple-kb-monitor"
HISTORY_FILE = STATE_DIR / "history.jsonl"
NOTIFIED_FILE = STATE_DIR / "low_notified"

# Known Apple Bluetooth keyboard product IDs
APPLE_PRODUCTS = {
    0x0205: "Apple Extended Keyboard II (M3501)",
    0x020B: "Apple Pro Keyboard (M7803)",
    0x020C: "Apple Extended Keyboard (M0115)",
    0x0220: "Apple Wireless Keyboard (A1016, white)",
    0x0229: "Apple Wireless Keyboard (A1255, aluminum, ANSI)",
    0x022C: "Apple Wireless Keyboard (A1255, aluminum, JIS)",
    0x0255: "Apple Wireless Keyboard (A1314, aluminum, ANSI)",
    0x0256: "Apple Wireless Keyboard (A1314, aluminum, ISO)",
    0x0257: "Apple Wireless Keyboard (A1314, aluminum, JIS)",
    0x024F: "Apple Magic Keyboard (A1644, ANSI)",
    0x0250: "Apple Magic Keyboard (A1644, ISO)",
    0x0267: "Apple Magic Keyboard with Touch ID (A2449, ANSI)",
    0x026C: "Apple Magic Keyboard with Touch ID (A2449, ISO)",
}

# BCM chip identification by firmware traits
BCM_CHIPS = {
    # (product_id_range_start, product_id_range_end): chip
    (0x0220, 0x022C): "Broadcom BCM2042 (ARM7TDMI, BT 2.0+EDR)",
    (0x0255, 0x0257): "Broadcom BCM2042 (ARM7TDMI, BT 2.0+EDR)",
    (0x024F, 0x0250): "Broadcom BCM20733 (ARM Cortex-M3, BT 4.0 LE)",
    (0x0267, 0x026C): "Broadcom BCM20733 (ARM Cortex-M3, BT 4.0 LE)",
}


def identify_chip(pid):
    for (lo, hi), chip in BCM_CHIPS.items():
        if lo <= pid <= hi:
            return chip
    return "Broadcom (unknown variant)"


# ---------------------------------------------------------------------------
# Device discovery
# ---------------------------------------------------------------------------

def find_devices():
    """Find all Apple Bluetooth keyboards via hidraw sysfs."""
    devices = []
    for hidraw in sorted(glob.glob("/sys/class/hidraw/hidraw*")):
        uevent_path = os.path.join(hidraw, "device", "uevent")
        try:
            uevent = Path(uevent_path).read_text()
        except OSError:
            continue
        props = dict(
            line.split("=", 1)
            for line in uevent.strip().splitlines()
            if "=" in line
        )
        hid_id = props.get("HID_ID", "")
        parts = hid_id.split(":")
        if len(parts) != 3:
            continue
        bus, vid, pid = parts
        if bus != "0005":
            continue
        if int(vid, 16) != APPLE_VID:
            continue

        pid_int = int(pid, 16)
        mac = props.get("HID_UNIQ", "")
        devnode = f"/dev/{os.path.basename(hidraw)}"
        ps_path = f"/sys/class/power_supply/hid-{mac}-battery" if mac else None

        # Find evdev input
        evdev = None
        for inp in glob.glob(os.path.join(hidraw, "device", "input", "input*")):
            for ev in glob.glob(os.path.join(inp, "event*")):
                evdev = f"/dev/input/{os.path.basename(ev)}"
                break

        devices.append({
            "path": devnode,
            "sysfs": hidraw,
            "name": props.get("HID_NAME", "Apple Keyboard"),
            "mac": mac,
            "pid": pid_int,
            "model": APPLE_PRODUCTS.get(pid_int, f"Apple Keyboard (0x{pid_int:04X})"),
            "chip": identify_chip(pid_int),
            "ps_path": ps_path,
            "evdev": evdev,
            "driver": props.get("DRIVER", ""),
        })
    return devices


# ---------------------------------------------------------------------------
# HID Feature Report reads
# ---------------------------------------------------------------------------

def hid_get_feature(devpath, report_id, length=16):
    """Read a HID Feature Report from hidraw device."""
    fd = None
    try:
        fd = os.open(devpath, os.O_RDWR)
        buf = bytearray(length)
        buf[0] = report_id
        fcntl.ioctl(fd, HIDIOCGFEATURE(length), buf)
        return bytes(buf)
    except (OSError, IOError):
        return None
    finally:
        if fd is not None:
            os.close(fd)


def read_all_reports(devpath):
    """Read all known Feature Reports and return decoded dict."""
    r = {}

    # Battery percentage (standard)
    d = hid_get_feature(devpath, REP_BATTERY_PCT)
    if d and d[0] == REP_BATTERY_PCT:
        r["battery_pct"] = d[1]

    # Battery precise (vendor)
    d = hid_get_feature(devpath, REP_BATTERY_FINE)
    if d and d[0] == REP_BATTERY_FINE:
        r["battery_fine"] = d[1]

    # Raw ADC voltage
    d = hid_get_feature(devpath, REP_ADC_VOLTAGE)
    if d and d[0] == REP_ADC_VOLTAGE:
        raw = (d[1] << 8) | d[2]
        r["adc_raw"] = raw
        if raw <= ADC_MAX:
            r["voltage"] = round(raw / ADC_MAX * ADC_VREF, 3)

    # ADC reference
    d = hid_get_feature(devpath, REP_ADC_REF)
    if d and d[0] == REP_ADC_REF:
        r["adc_ref"] = (d[1] << 8) | d[2]

    # Calibration curve (4 x 16-bit thresholds in millivolts)
    d = hid_get_feature(devpath, REP_CALIB_CURVE)
    if d and d[0] == REP_CALIB_CURVE:
        thresholds_mv = []
        for i in range(4):
            off = 1 + i * 2
            thresholds_mv.append((d[off] << 8) | d[off + 1])
        r["calib_thresholds_mv"] = thresholds_mv
        r["calib_voltages"] = [round(t / 1000, 3) for t in thresholds_mv]

    # Voltage reference pair
    d = hid_get_feature(devpath, REP_VOLT_REF)
    if d and d[0] == REP_VOLT_REF:
        r["volt_ref_1"] = (d[1] << 8) | d[2]
        r["volt_ref_2"] = (d[3] << 8) | d[4]

    # Firmware version
    d = hid_get_feature(devpath, REP_FW_VERSION)
    if d and d[0] == REP_FW_VERSION:
        r["fw_byte"] = d[1]
        r["fw_version"] = f"{d[1] >> 4}.{d[1] & 0x0F}"

    # Build/revision
    d = hid_get_feature(devpath, REP_BUILD_REV)
    if d and d[0] == REP_BUILD_REV:
        r["build_number"] = (d[1] << 8) | d[2]
        r["build_flag"] = d[3]

    # Device name (3 chunks)
    name_parts = []
    for rid in [REP_NAME_1, REP_NAME_2, REP_NAME_3]:
        d = hid_get_feature(devpath, rid)
        if d and d[0] == rid:
            name_parts.append(d[1:16].split(b"\x00")[0].decode("ascii", errors="replace"))
    if name_parts:
        r["device_name"] = "".join(name_parts)

    # Device identity (128-bit)
    d = hid_get_feature(devpath, REP_IDENTITY)
    if d and d[0] == REP_IDENTITY:
        r["identity_type"] = d[1]
        r["identity_key"] = d[2:16].hex()

    # Device state
    d = hid_get_feature(devpath, REP_DEVICE_STATE)
    if d and d[0] == REP_DEVICE_STATE:
        r["state_flag"] = d[1]

    # BT connection params
    d = hid_get_feature(devpath, REP_BT_CONN_PARAMS)
    if d and d[0] == REP_BT_CONN_PARAMS:
        r["bt_interval"] = d[1]
        r["bt_latency"] = d[2]

    # BT timing
    d = hid_get_feature(devpath, REP_BT_TIMING)
    if d and d[0] == REP_BT_TIMING:
        r["bt_timeout"] = d[1]
        r["bt_timing_2"] = d[2]

    # Power config
    d = hid_get_feature(devpath, REP_POWER_CFG)
    if d and d[0] == REP_POWER_CFG:
        r["power_cfg"] = d[1]

    # Mode/class
    d = hid_get_feature(devpath, REP_MODE_CLASS)
    if d and d[0] == REP_MODE_CLASS:
        r["mode"] = d[1]
        r["dev_class"] = d[2]

    # Config registers
    for rid, key in [(REP_CFG_REG_1, "cfg_reg_1"), (REP_CFG_REG_2, "cfg_reg_2")]:
        d = hid_get_feature(devpath, rid)
        if d and d[0] == rid:
            r[key] = d[1:4].hex()

    return r


# ---------------------------------------------------------------------------
# Raw dump (all 256 report IDs)
# ---------------------------------------------------------------------------

def dump_all_reports(devpath):
    """Scan all 256 Feature Report IDs, return those with data."""
    results = []
    fd = None
    try:
        fd = os.open(devpath, os.O_RDWR)
        for rid in range(256):
            buf = bytearray(64)
            buf[0] = rid
            try:
                fcntl.ioctl(fd, HIDIOCGFEATURE(64), buf)
                if any(buf[1:]):
                    # Find last non-zero byte for display
                    last = 63
                    while last > 0 and buf[last] == 0:
                        last -= 1
                    results.append((rid, bytes(buf[: last + 1])))
            except (OSError, IOError):
                pass
    finally:
        if fd is not None:
            os.close(fd)
    return results


# ---------------------------------------------------------------------------
# BlueZ MGMT (RSSI / TX Power)
# ---------------------------------------------------------------------------

def get_conn_info(mac):
    """Get RSSI and TX power via BlueZ MGMT GET_CONN_INFO.

    Sends MGMT opcode 0x0031 which triggers HCI Read_RSSI + Read_TX_Power
    on the ACL connection handle. Safe on uhid BR/EDR connections (tested
    with 10 consecutive reads without disconnect).

    Note: RSSI=0 dBm is a valid value meaning optimal signal ("golden range"),
    not "unavailable". The controller returns the real measured RSSI.
    """
    try:
        sock = socket.socket(31, socket.SOCK_RAW, BTPROTO_HCI)
        sock.bind((0xFFFF, HCI_CHANNEL_CONTROL))
        sock.settimeout(2)

        addr_bytes = bytes(int(x, 16) for x in mac.split(":"))
        addr_le = bytes(reversed(addr_bytes))
        payload = addr_le + struct.pack("B", 0x00)

        header = struct.pack("<HHH", MGMT_OP_GET_CONN_INFO, 0, len(payload))
        sock.send(header + payload)
        data = sock.recv(1024)
        sock.close()

        if len(data) < 19:
            return None
        if struct.unpack_from("<H", data, 0)[0] != MGMT_EV_CMD_COMPLETE:
            return None
        if data[8] != 0:
            return None

        rssi = struct.unpack_from("<b", data, 16)[0]
        tx_power = struct.unpack_from("<b", data, 17)[0]
        max_tx = struct.unpack_from("<b", data, 18)[0]

        return {"rssi_dbm": rssi, "tx_power_dbm": tx_power, "max_tx_power_dbm": max_tx}
    except (OSError, TimeoutError, PermissionError):
        return None


def rssi_quality(rssi):
    if rssi is None:
        return "N/A"
    if rssi >= -10:
        return "Optimal (golden range)"
    if rssi >= -65:
        return "Good"
    if rssi >= -80:
        return "Fair"
    return "Poor"


# ---------------------------------------------------------------------------
# BlueZ D-Bus properties
# ---------------------------------------------------------------------------

def get_bluez_props(mac):
    """Get device properties via BlueZ D-Bus."""
    import re
    obj_path = "/org/bluez/hci0/dev_" + mac.upper().replace(":", "_")
    try:
        out = subprocess.run(
            ["dbus-send", "--system", "--print-reply", "--dest=org.bluez",
             obj_path, "org.freedesktop.DBus.Properties.GetAll",
             "string:org.bluez.Device1"],
            capture_output=True, text=True, timeout=3,
        )
        if out.returncode != 0:
            return {}
        props = {}
        for key, val_str in re.findall(r'string\s+"([^"]+)"\s*\n\s*variant\s+(.*)', out.stdout):
            val_str = val_str.strip()
            if val_str.startswith("boolean"):
                props[key] = val_str.split()[-1] == "true"
            elif val_str.startswith(("uint32", "int16", "int32", "uint16")):
                try:
                    props[key] = int(val_str.split()[-1])
                except ValueError:
                    pass
            elif val_str.startswith("string"):
                m = re.search(r'"([^"]*)"', val_str)
                if m:
                    props[key] = m.group(1)
            elif val_str.startswith("object path"):
                m = re.search(r'"([^"]*)"', val_str)
                if m:
                    props[key] = m.group(1)
        return props
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return {}


def parse_modalias(modalias):
    if not modalias or not modalias.startswith("usb:"):
        return None
    try:
        p = modalias[4:]
        return {
            "vendor_id": f"0x{int(p[1:5], 16):04X}",
            "product_id": f"0x{int(p[6:10], 16):04X}",
            "fw_version": f"{int(p[11:15], 16) >> 8}.{int(p[11:15], 16) & 0xFF:02d}",
        }
    except (ValueError, IndexError):
        return None


# ---------------------------------------------------------------------------
# sysfs
# ---------------------------------------------------------------------------

def read_sysfs(ps_path):
    if not ps_path or not os.path.isdir(ps_path):
        return {}
    result = {}
    for attr in ["capacity", "status", "present", "scope", "model_name", "type"]:
        try:
            result[attr] = (Path(ps_path) / attr).read_text().strip()
        except OSError:
            pass
    return result


# ---------------------------------------------------------------------------
# Input capabilities
# ---------------------------------------------------------------------------

def read_input_caps(evdev):
    if not evdev:
        return {}
    sysfs = f"/sys/class/input/{os.path.basename(evdev)}/device"
    result = {}
    for attr in ["name", "phys", "uniq"]:
        try:
            result[attr] = (Path(sysfs) / attr).read_text().strip()
        except OSError:
            pass
    cap_dir = Path(sysfs) / "capabilities"
    if cap_dir.is_dir():
        caps = {}
        for f in cap_dir.iterdir():
            try:
                caps[f.name] = f.read_text().strip()
            except OSError:
                pass
        result["capabilities"] = caps
    return result


# ---------------------------------------------------------------------------
# Full report collection
# ---------------------------------------------------------------------------

def collect_report(dev):
    """Collect all telemetry into a single dict."""
    reps = read_all_reports(dev["path"])
    bluez = get_bluez_props(dev["mac"]) if dev["mac"] else {}
    conn = get_conn_info(dev["mac"]) if dev["mac"] else None
    sysfs = read_sysfs(dev.get("ps_path"))
    inp = read_input_caps(dev.get("evdev"))
    fw_modal = parse_modalias(bluez.get("Modalias", ""))

    report = {
        "timestamp": datetime.now().isoformat(),
        "device": {
            "model": dev["model"],
            "name": reps.get("device_name", dev["name"]),
            "mac": dev["mac"],
            "chip": dev["chip"],
            "driver": dev["driver"],
            "hidraw": dev["path"],
            "evdev": dev.get("evdev"),
        },
        "firmware": {
            "version": reps.get("fw_version"),
            "build": reps.get("build_number"),
            "build_flag": reps.get("build_flag"),
            "modalias": fw_modal,
        },
        "battery": {
            "percentage": reps.get("battery_pct"),
            "percentage_fine": reps.get("battery_fine"),
            "adc_raw": reps.get("adc_raw"),
            "voltage": reps.get("voltage"),
            "adc_ref": reps.get("adc_ref"),
        },
        "calibration": {
            "thresholds_mv": reps.get("calib_thresholds_mv"),
            "thresholds_volts": reps.get("calib_voltages"),
            "volt_ref_1": reps.get("volt_ref_1"),
            "volt_ref_2": reps.get("volt_ref_2"),
        },
        "state": {
            "flag": reps.get("state_flag"),
            "power_cfg": reps.get("power_cfg"),
            "mode": reps.get("mode"),
            "dev_class": reps.get("dev_class"),
        },
        "bluetooth": {
            "connected": bluez.get("Connected", False),
            "paired": bluez.get("Paired", False),
            "bonded": bluez.get("Bonded", False),
            "trusted": bluez.get("Trusted", False),
            "legacy_pairing": bluez.get("LegacyPairing", False),
            "wake_allowed": bluez.get("WakeAllowed", False),
            "class": f"0x{bluez['Class']:08X}" if isinstance(bluez.get("Class"), int) else None,
            "interval": reps.get("bt_interval"),
            "latency": reps.get("bt_latency"),
            "timeout": reps.get("bt_timeout"),
        },
        "radio": conn or {},
        "identity": {
            "type": reps.get("identity_type"),
            "key": reps.get("identity_key"),
        },
        "sysfs": sysfs,
        "input": inp,
        "config_registers": {
            "0xF6": reps.get("cfg_reg_1"),
            "0xF7": reps.get("cfg_reg_2"),
        },
    }
    return report


# ---------------------------------------------------------------------------
# Output: pretty report
# ---------------------------------------------------------------------------

def bar(pct, width=20):
    if pct is None:
        return ""
    filled = round(pct / 100 * width)
    return f"[{'#' * filled}{'.' * (width - filled)}]"


def voltage_health(v):
    """Interpret 2xAA battery voltage."""
    if v is None:
        return ""
    if v >= 2.8:
        return "Fresh"
    if v >= 2.4:
        return "Good"
    if v >= 2.1:
        return "Low"
    if v >= 1.8:
        return "Critical"
    return "Dead"


def print_report(r):
    d = r["device"]
    fw = r["firmware"]
    b = r["battery"]
    cal = r["calibration"]
    st = r["state"]
    bt = r["bluetooth"]
    radio = r["radio"]
    ident = r["identity"]
    sysfs = r["sysfs"]
    inp = r["input"]
    cfg = r["config_registers"]

    W = 65
    print("=" * W)
    print(f"  APPLE KEYBOARD MONITOR v{__version__}")
    print(f"  {r['timestamp']}")
    print("=" * W)

    print(f"\n  DEVICE")
    print(f"  {'Model':22s} {d['model']}")
    print(f"  {'Name (from chip)':22s} {d['name']}")
    print(f"  {'MAC':22s} {d['mac']}")
    print(f"  {'Controller':22s} {d['chip']}")
    print(f"  {'Kernel driver':22s} {d['driver']}")
    print(f"  {'HID device':22s} {d['hidraw']}")
    print(f"  {'Input device':22s} {d.get('evdev') or 'N/A'}")

    print(f"\n  FIRMWARE")
    print(f"  {'Version':22s} {fw.get('version') or '?'}")
    print(f"  {'Build':22s} {fw.get('build') or '?'}")
    if fw.get("modalias"):
        print(f"  {'Modalias version':22s} {fw['modalias'].get('fw_version', '?')}")
    print(f"  {'Flashable':22s} No (signed ROM)")

    pct = b.get("percentage")
    fine = b.get("percentage_fine")
    volts = b.get("voltage")
    adc = b.get("adc_raw")

    print(f"\n  BATTERY")
    print(f"  {'Reported (0x47)':22s} {pct}% {bar(pct)}" if pct is not None else f"  {'Reported':22s} N/A")
    print(f"  {'Precise  (0xEA)':22s} {fine}%" if fine is not None else f"  {'Precise':22s} N/A")
    if volts is not None:
        print(f"  {'Voltage  (0xF5)':22s} {volts:.3f} V  (ADC raw: {adc})")
        print(f"  {'Cell health':22s} {voltage_health(volts)}")
    adc_ref = b.get("adc_ref")
    if adc_ref is not None:
        print(f"  {'ADC ref  (0xF4)':22s} {adc_ref}")
    print(f"  {'sysfs status':22s} {sysfs.get('status', 'N/A')}")

    if cal.get("thresholds_mv"):
        print(f"\n  DISCHARGE CURVE (0x5A)")
        labels = ["100%", " 75%", " 50%", " 25%"]
        for i, (mv, volt) in enumerate(zip(cal["thresholds_mv"], cal["thresholds_volts"])):
            marker = " <-- current" if volts and abs(volts - volt) < 0.15 else ""
            print(f"  {'  ' + labels[i]:22s} {mv:4d} mV  ({volt:.3f} V){marker}")

    print(f"\n  DEVICE STATE")
    flag = st.get("flag")
    print(f"  {'State (0x09)':22s} {'OK' if flag == 1 else 'LOW' if flag == 0 else f'{flag}'}")
    print(f"  {'Power config (0x4A)':22s} {st.get('power_cfg', '?')}")
    print(f"  {'Mode (0x4B)':22s} {st.get('mode', '?')}")
    print(f"  {'Class (0x4B)':22s} {st.get('dev_class', '?')}")

    if ident.get("key"):
        print(f"\n  IDENTITY (0x4C)")
        print(f"  {'Type':22s} {ident['type']}")
        print(f"  {'Key (128-bit)':22s} {ident['key']}")

    print(f"\n  BLUETOOTH")
    print(f"  {'Connected':22s} {'Yes' if bt.get('connected') else 'No'}")
    print(f"  {'Paired':22s} {'Yes' if bt.get('paired') else 'No'}")
    print(f"  {'Bonded':22s} {'Yes' if bt.get('bonded') else 'No'}")
    print(f"  {'Trusted':22s} {'Yes' if bt.get('trusted') else 'No'}")
    print(f"  {'Legacy pairing':22s} {'Yes' if bt.get('legacy_pairing') else 'No'}")
    print(f"  {'Wake allowed':22s} {'Yes' if bt.get('wake_allowed') else 'No'}")
    if bt.get("class"):
        print(f"  {'Device class':22s} {bt['class']}")
    if bt.get("interval") is not None:
        print(f"  {'Conn interval (0x46)':22s} {bt['interval']} ({bt['interval'] * 1.25:.1f} ms)")
    if bt.get("latency") is not None:
        print(f"  {'Conn latency (0x46)':22s} {bt['latency']}")
    if bt.get("timeout") is not None:
        print(f"  {'Supervision TO (0x49)':22s} {bt['timeout']}")

    if radio:
        print(f"\n  RADIO")
        rssi = radio.get("rssi_dbm")
        if rssi is not None:
            print(f"  {'RSSI':22s} {rssi} dBm ({rssi_quality(rssi)})")
        print(f"  {'TX power':22s} {radio.get('tx_power_dbm', '?')} dBm")
        print(f"  {'Max TX power':22s} {radio.get('max_tx_power_dbm', '?')} dBm")
    else:
        print(f"\n  RADIO")
        print(f"  {'RSSI':22s} N/A (device not connected or no permission)")
        print(f"  {'TX power':22s} N/A")

    if inp:
        caps = inp.get("capabilities", {})
        print(f"\n  INPUT")
        print(f"  {'Phys':22s} {inp.get('phys', '?')}")
        if "ev" in caps:
            ev = int(caps["ev"], 16)
            names = {0: "SYN", 1: "KEY", 2: "REL", 3: "ABS", 4: "MSC", 17: "LED", 20: "REP"}
            evtypes = [n for b, n in names.items() if ev & (1 << b)]
            print(f"  {'Event types':22s} {', '.join(evtypes)}")
        if "led" in caps:
            print(f"  {'LEDs':22s} NumLock, CapsLock, ScrollLock, Compose, Kana")

    if any(v for v in cfg.values()):
        print(f"\n  CONFIG REGISTERS")
        for reg, val in cfg.items():
            if val:
                print(f"  {reg:22s} {val}")

    print(f"\n{'=' * W}")


# ---------------------------------------------------------------------------
# Output: raw dump
# ---------------------------------------------------------------------------

def print_dump(devpath):
    reports = dump_all_reports(devpath)
    print(f"{'=' * 65}")
    print(f"  RAW HID FEATURE REPORT DUMP")
    print(f"{'=' * 65}")
    for rid, data in reports:
        # Attempt ASCII decode for string-like reports
        ascii_part = ""
        printable = data[1:]
        if all(32 <= b < 127 for b in printable if b != 0):
            ascii_part = f'  "{printable.split(b"\\x00")[0].decode("ascii", errors="replace")}"'
        print(f"  0x{rid:02X}  {data.hex()}{ascii_part}")
    print(f"\n  Total: {len(reports)} reports with data")
    print(f"{'=' * 65}")


# ---------------------------------------------------------------------------
# Notification
# ---------------------------------------------------------------------------

def notify(title, body, urgency="normal", icon="battery-low"):
    try:
        subprocess.run(
            ["notify-send", f"--urgency={urgency}", f"--icon={icon}",
             "--app-name=Apple KB Monitor", title, body],
            timeout=5, capture_output=True,
        )
    except FileNotFoundError:
        pass


# ---------------------------------------------------------------------------
# History
# ---------------------------------------------------------------------------

def append_history(entry):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with open(HISTORY_FILE, "a") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")
    try:
        lines = HISTORY_FILE.read_text().splitlines()
        if len(lines) > 2000:
            HISTORY_FILE.write_text("\n".join(lines[-2000:]) + "\n")
    except OSError:
        pass


def print_history():
    if not HISTORY_FILE.exists():
        print("No history yet.", file=sys.stderr)
        return
    lines = HISTORY_FILE.read_text().splitlines()
    print(f"  {'Timestamp':20s} {'Bat%':>5s} {'Fine%':>6s} {'Voltage':>8s} {'RSSI':>6s}")
    print(f"  {'─' * 20} {'─' * 5} {'─' * 6} {'─' * 8} {'─' * 6}")
    for line in lines[-100:]:
        try:
            e = json.loads(line)
            t = e.get("t", "?")[:19]
            bat = e.get("bat", "")
            fine = e.get("fine", "")
            volt = e.get("volt", "")
            rssi = e.get("rssi", "")
            volt_s = f"{volt:.3f}V" if isinstance(volt, (int, float)) else ""
            rssi_s = f"{rssi}dBm" if rssi else ""
            print(f"  {t:20s} {str(bat):>5s} {str(fine):>6s} {volt_s:>8s} {rssi_s:>6s}")
        except json.JSONDecodeError:
            pass


# ---------------------------------------------------------------------------
# Daemon
# ---------------------------------------------------------------------------

def daemon_loop(threshold, interval):
    STATE_DIR.mkdir(parents=True, exist_ok=True)

    def handle_signal(signum, frame):
        sys.exit(0)
    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    while True:
        for dev in find_devices():
            reps = read_all_reports(dev["path"])
            pct = reps.get("battery_pct")
            fine = reps.get("battery_fine")
            volts = reps.get("voltage")
            adc = reps.get("adc_raw")
            if pct is None and fine is None:
                continue

            entry = {
                "t": datetime.now().isoformat(),
                "mac": dev["mac"],
                "bat": pct,
                "fine": fine,
                "volt": volts,
                "adc": adc,
            }
            conn = get_conn_info(dev["mac"]) if dev["mac"] else None
            if conn:
                entry["rssi"] = conn["rssi_dbm"]
                entry["tx"] = conn["tx_power_dbm"]
            append_history(entry)

            level = fine if fine is not None else pct
            if level is not None and level <= threshold:
                if not NOTIFIED_FILE.exists():
                    urgency = "critical" if level <= 5 else "normal"
                    icon = "battery-caution" if level <= 5 else "battery-low"
                    v_str = f" ({volts:.2f}V)" if volts else ""
                    notify(
                        f"Batterie faible — {dev['name']}",
                        f"{level}%{v_str} restant",
                        urgency=urgency, icon=icon,
                    )
                    NOTIFIED_FILE.write_text(str(level))
            elif level is not None and level > threshold:
                if NOTIFIED_FILE.exists():
                    NOTIFIED_FILE.unlink(missing_ok=True)

        time.sleep(interval)


# ---------------------------------------------------------------------------
# Watch
# ---------------------------------------------------------------------------

def watch_mode(interval):
    try:
        while True:
            os.system("clear")
            devices = find_devices()
            if not devices:
                print("  Waiting for Apple Bluetooth keyboard...")
            for dev in devices:
                r = collect_report(dev)
                print_report(r)
            print(f"\n  Refresh: {interval}s — Ctrl+C to quit")
            time.sleep(interval)
    except KeyboardInterrupt:
        pass


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    global socket
    import socket as _socket
    socket = _socket

    p = argparse.ArgumentParser(
        description=f"Apple Keyboard Monitor v{__version__} — BCM2042/BCM20733 telemetry",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
examples:
  apple-kb-monitor --once          Quick battery + voltage
  apple-kb-monitor --status        Full decoded report
  apple-kb-monitor --dump          Raw register dump (RE)
  apple-kb-monitor --watch         Live dashboard
  apple-kb-monitor --json          JSON for scripting
  apple-kb-monitor --history       Battery/voltage log
  apple-kb-monitor                 Daemon (systemd)

project: https://github.com/agenceapi/apple-kb-monitor
license: GPL-2.0-or-later
""",
    )
    p.add_argument("--version", action="version", version=f"%(prog)s {__version__}")
    mode = p.add_mutually_exclusive_group()
    mode.add_argument("--once", action="store_true", help="Quick battery + voltage, exit")
    mode.add_argument("--status", action="store_true", help="Full decoded device report")
    mode.add_argument("--dump", action="store_true", help="Raw Feature Report dump")
    mode.add_argument("--watch", action="store_true", help="Live dashboard")
    mode.add_argument("--json", action="store_true", help="JSON output")
    mode.add_argument("--history", action="store_true", help="Show battery/voltage log")

    p.add_argument("--threshold", type=int, default=15, help="Low battery notification %% (default: 15)")
    p.add_argument("--interval", type=int, default=300, help="Daemon poll interval in seconds (default: 300)")
    p.add_argument("--watch-interval", type=int, default=5, help="Watch refresh in seconds (default: 5)")
    args = p.parse_args()

    devices = find_devices()

    if args.once:
        if not devices:
            print("No Apple Bluetooth keyboard found.", file=sys.stderr)
            sys.exit(1)
        for dev in devices:
            reps = read_all_reports(dev["path"])
            pct = reps.get("battery_pct")
            fine = reps.get("battery_fine")
            volts = reps.get("voltage")
            adc = reps.get("adc_raw")
            conn = get_conn_info(dev["mac"]) if dev["mac"] else None
            rssi_s = f"  RSSI:{conn['rssi_dbm']}dBm" if conn and conn.get("rssi_dbm") else ""
            volt_s = f"  {volts:.3f}V" if volts else ""
            fine_s = f" (fine:{fine}%)" if fine is not None and fine != pct else ""
            print(f"{dev['model']:48s} {pct}%{fine_s}{volt_s}{rssi_s}")

    elif args.status:
        if not devices:
            print("No Apple Bluetooth keyboard found.", file=sys.stderr)
            sys.exit(1)
        for dev in devices:
            print_report(collect_report(dev))

    elif args.dump:
        if not devices:
            print("No Apple Bluetooth keyboard found.", file=sys.stderr)
            sys.exit(1)
        for dev in devices:
            print(f"\n  Device: {dev['name']} [{dev['mac']}] @ {dev['path']}")
            print_dump(dev["path"])

    elif args.json:
        if not devices:
            json.dump({"error": "no device"}, sys.stdout, indent=2)
            sys.exit(1)
        reports = [collect_report(dev) for dev in devices]
        json.dump(reports[0] if len(reports) == 1 else reports,
                  sys.stdout, indent=2, ensure_ascii=False)
        print()

    elif args.watch:
        watch_mode(args.watch_interval)

    elif args.history:
        print_history()

    else:
        daemon_loop(args.threshold, args.interval)


if __name__ == "__main__":
    main()
